{
  "name": "codeyourcareer",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "node --watch server/index.js",
    "dev:full": "concurrently \"npm:dev:api\" \"npm:dev\"",
    "build": "vite build",
    "build:analyze": "vite build --mode analyze",
    "preview": "vite preview",
    "start": "node server/index.js",
    "seed:admin": "node server/scripts/seed-admin.js",
    "seed:demo": "node server/scripts/seed-demo.js",
    "test": "node tests/api.test.js",
    "check": "npm run build && npm run test"
  },
  "dependencies": {
    "animejs": "^3.2.2",
    "bcryptjs": "^2.4.3",
    "cookie-session": "^2.1.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "multer": "^2.0.2",
    "mysql2": "^3.14.1",
    "vite": "^6.2.1"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "rollup-plugin-visualizer": "^7.0.1"
  }
}
